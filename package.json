{
  "name": "bot-colorado-v2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "rm -rf server/dist && cd server && npm install && npx tsc && cd ../client && npm install && npx vite build && cd .. && npx prisma db push --accept-data-loss && npx prisma generate",
    "start": "node server/dist/index.js",
    "dev": "concurrently \"cd server && npm run dev\" \"cd client && npm run dev\"",
    "prisma:generate": "npx prisma generate",
    "prisma:push": "npx prisma db push --accept-data-loss"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.474.0",
    "mime-types": "^3.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "node-machine-id": "^1.1.12",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "uuid": "^13.0.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.5"
  }
}
